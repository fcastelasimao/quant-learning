GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash   # 1500 req/day free. Use gemini-2.5-flash for quality (20 req/day free)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
LLM_PROVIDER=groq               # Primary provider. Fallback chain: groq → cerebras → deepseek → together → mistral → gemini → openrouter

# Optional: allow failover on 403/network-policy access denials.
# Default is strict: non-quota errors propagate so you can fix configuration.
LLM_FAILOVER_ON_ACCESS_DENIED=0

# Compatibility: some docs/tools use GOOGLE_API_KEY for Gemini (AI Studio).
# qframe will accept either GOOGLE_API_KEY or GEMINI_API_KEY.
GOOGLE_API_KEY=

# OpenAI-compatible providers (optional — add keys to enable in fallback chain)
CEREBRAS_API_KEY=               # 1M tokens/min free. Same model as Groq. Recommended first backup.
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507  # or llama3.1-8b for lower latency
TOGETHER_API_KEY=               # Generous free credits on signup. together.ai
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
DEEPSEEK_API_KEY=               # Very cheap ($0.07/M tokens), strong reasoning. platform.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
MISTRAL_API_KEY=                # EU-hosted, free tier on console.mistral.ai
MISTRAL_MODEL=mistral-large-latest
OPENROUTER_API_KEY=             # Last-resort aggregator — routes to 100+ models. openrouter.ai
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
